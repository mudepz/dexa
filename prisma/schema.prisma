generator client {
  provider = "prisma-client-js"
  output   = ".././node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model permission {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar
  created_at DateTime @default(now()) @db.Timestamptz(6)

  role_permission role_permission[]
}

model role {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar
  created_at DateTime @default(now()) @db.Timestamptz(6)

  role_permissions role_permission[]
  employees        employee[]
}

model role_permission {
  id            BigInt   @id @default(autoincrement())
  role_id       Int
  permission_id Int
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  permission permission @relation(fields: [permission_id], references: [id], onDelete: Restrict)
  role       role       @relation(fields: [role_id], references: [id], onDelete: Restrict)

  @@unique([role_id, permission_id])
}

model employee {
  id            BigInt    @id @default(autoincrement())
  email         String    @unique @db.VarChar
  phone_number  String?   @db.VarChar
  position      String?   @db.VarChar
  salt          String    @db.VarChar
  password      String    @db.VarChar
  full_name     String    @db.VarChar
  photo_key     String?   @db.VarChar
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)
  deleted_at    DateTime? @db.Timestamptz(6)
  role_id       Int
  created_by_id BigInt?

  role             role           @relation(fields: [role_id], references: [id])
  created_by       employee?      @relation("createdBy", fields: [created_by_id], references: [id])
  employee_created employee[]     @relation("createdBy")
  attendances      attendance[]
  logs             employee_log[]
}

model attendance {
  id          BigInt    @id @default(autoincrement())
  employee_id BigInt
  tap_in_at   DateTime  @default(now()) @db.Timestamptz(6)
  tap_out_at  DateTime? @db.Timestamptz(6)

  employee employee @relation(fields: [employee_id], references: [id])
}

model employee_log {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now()) @db.Timestamptz(6)
  employee_id BigInt
  old_value   Json?
  new_value   Json?

  employee employee? @relation(fields: [employee_id], references: [id])
}
