{
  "name": "dexa-api",
  "version": "1.0.0",
  "main": "dist/src/main.ts",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:deploy": "npm run deploy-prisma && node dist/src/main.js",
    "start:deploy-debug": "npm run deploy-prisma:debug && nest start --debug --watch",
    "start:debug": "nest start --debug --watch",
    "deploy-prisma": "npx prisma migrate deploy && npx prisma generate && node dist/prisma/seed.js",
    "deploy-prisma:debug": "npx prisma migrate deploy && npx prisma generate && npx prisma db seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.2",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "^6.2.0",
    "aws-sdk": "^2.1693.0",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "ethers": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "2.0.2",
    "nodemailer": "^7.0.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@nestjs/cli": "^10.4.9",
    "@types/body-parser": "^1.19.5",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.9",
    "@types/nodemailer": "^6.4.17",
    "@types/semver": "^7.7.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
